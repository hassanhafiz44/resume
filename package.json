{
  "name": "resume",
  "dependencies": {
    "hono": "^4",
    "react": "^18",
    "react-dom": "^18",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.16.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/bun": "latest",
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "scripts": {
    "dev": "bun run --hot src/server.ts",
    "build:css": "bunx @tailwindcss/cli -i src/client/styles/tailwind.css -o public/dist/main.css --minify",
    "build:js": "bun build src/client/main.tsx --outdir public/dist --target browser --minify",
    "build:prerender": "bun scripts/prerender.tsx",
    "build": "bun run build:css && bun run build:js && bun run build:prerender"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
